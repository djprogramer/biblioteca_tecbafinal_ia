# Configuración de la API de Gemini AI
GEMINI_API_KEY=tu_api_key_aqui

# Configuración de Redis (opcional - si no está, usará archivos)
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_PREFIX=ai_cache:

# Configuración de la base de datos (si es necesario)
# DB_HOST=localhost
# DB_NAME=biblioteca
# DB_USER=root
# DB_PASS=

# Configuración del sistema (opcional - sobreescribe los valores por defecto)
# AI_MAX_TOKENS=1000
# AI_TEMPERATURE=0.7
# AI_TOP_P=0.8
# AI_TOP_K=40
# AI_MAX_REQUESTS_PER_DAY=50
# AI_MAX_REQUESTS_PER_HOUR=10
# AI_CACHE_DURATION=3600

# Límites por rol (configurados en base de datos)
# Estos valores se usan como fallback si la tabla ai_role_limits no existe
# admin: 999999 diario, 999999 por hora (ilimitado)
# super_admin: 999999 diario, 999999 por hora (ilimitado)
# administrativo: 999999 diario, 999999 por hora (ilimitado)
# docente: 50 diario, 10 por hora
# estudiante: 25 diario, 5 por hora
# usuario: 25 diario, 5 por hora

# Instrucciones:
# 1. Copia este archivo a .env
# 2. Reemplaza "tu_api_key_aqui" con tu API key real de Gemini
# 3. Configura Redis si tienes disponible (opcional pero recomendado)
# 4. Ejecuta el script database/create_ai_role_limits.sql para configurar límites por rol
# 5. Accede a admin/ai_limits.php para ajustar los límites según necesites
# 6. Configura las variables adicionales según necesites
